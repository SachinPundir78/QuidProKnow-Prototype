# ============================================================
# Brofessor Backend Configuration (Example)
# ============================================================

server.port=${PORT:8080}

# --- MySQL ---
spring.datasource.url=${DB_URL:jdbc:mysql://localhost:3306/brofessor}
spring.datasource.username=${DB_USERNAME:your_db_username}
spring.datasource.password=${DB_PASSWORD:your_db_password}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# --- JPA ---
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.open-in-view=false

# --- JWT ---
jwt.secret=${JWT_SECRET:your_base64_jwt_secret}
jwt.expiration-ms=86400000

# --- CORS ---
app.cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:5173,https://your-frontend.vercel.app}

# --- SMTP / Contact Form ---
spring.mail.host=${SMTP_HOST:smtp.example.com}
spring.mail.port=${SMTP_PORT:587}
spring.mail.username=${SMTP_USERNAME:your_email_username}
spring.mail.password=${SMTP_PASSWORD:your_smtp_password}

spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
spring.mail.properties.mail.smtp.connectiontimeout=5000
spring.mail.properties.mail.smtp.timeout=5000
spring.mail.properties.mail.smtp.writetimeout=5000

app.mail.from=${MAIL_FROM:noreply@example.com}
app.contact.recipient=${CONTACT_RECIPIENT_EMAIL:admin@example.com}

# --- File Uploads ---
spring.servlet.multipart.max-file-size=5MB
spring.servlet.multipart.max-request-size=5MB

# --- Cloudinary ---
cloudinary.cloud-name=${CLOUDINARY_CLOUD_NAME:your_cloud_name}
cloudinary.api-key=${CLOUDINARY_API_KEY:your_cloudinary_api_key}
cloudinary.api-secret=${CLOUDINARY_API_SECRET:your_cloudinary_api_secret}

# --- Logging ---
logging.level.org.springframework.security=WARN
logging.level.com.brofessor=INFO

# --- AI Configuration ---
groq.api.key=${GROQ_API_KEY:your_groq_api_key}
gemini.api.key=${GEMINI_API_KEY:your_gemini_api_key}
